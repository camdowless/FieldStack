# ============================================
# Firebase Web App Config
# Found at: Firebase Console → Project Settings → General → Your Apps → Web App
# Copy these into frontend/.env (create it from this file)
# ============================================
VITE_FIREBASE_API_KEY=AIzaSy...your-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abc123def456

# ============================================
# Functions URL (local dev only)
# Printed when you run: firebase emulators:start --only functions
# Format: http://127.0.0.1:5001/{project-id}/{region}
# ============================================
VITE_FUNCTIONS_URL=http://127.0.0.1:5001/your-project-id/us-central1
