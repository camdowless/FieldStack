rules_version = '2';
service cloud.firestore {
  function isAdmin() {
    return request.auth != null && request.auth.token.role == "admin";
  }

  function hasUserRole() {
    return request.auth != null && (request.auth.token.role == "user" || request.auth.token.role == "admin");
  }

  match /databases/{database}/documents {
    match /admin/{document} {
      allow read: if isAdmin();
      allow write: if false; // server-side only via Admin SDK
    }

    // Webhook deduplication — server-side only
    match /processedWebhookEvents/{eventId} {
      allow read, write: if false; // Admin SDK only
    }

    // Rate limit counters — server-side only
    match /rateLimits/{docId} {
      allow read, write: if false; // Admin SDK only
    }

    // Plan configuration — readable by all authenticated users, writable only via Admin SDK
    match /plans/{planId} {
      allow read: if request.auth != null;
      allow write: if false; // server-side only via Admin SDK (seedPlans function)
    }

    // User reports — server-side only
    match /reports/{reportId} {
      allow read: if false; // admin-only via Admin SDK
      allow write: if false; // server-side only via Admin SDK
    }

    match /users/{uid} {
      function isOwner() {
        return request.auth != null && request.auth.uid == uid;
      }

      allow read: if isOwner();

      // Allow users to update only the preferences field on their own profile
      allow update: if isOwner()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["preferences"]);

      allow create: if false; // server-side only via Admin SDK

      match /preferences/{doc} {
        allow read, write: if isOwner();
      }

      // Dunning / payment notifications written by server, read-only for the user
      match /notifications/{notificationId} {
        allow read: if isOwner();
        allow write: if false; // server-side only via Admin SDK
      }
    }
  }
}
