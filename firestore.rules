rules_version = '2';
service cloud.firestore {
  function isAdmin() {
    return request.auth != null && request.auth.token.role == "admin";
  }

  function hasUserRole() {
    return request.auth != null && (request.auth.token.role == "user" || request.auth.token.role == "admin");
  }

  function isAuthenticated() {
    return request.auth != null;
  }

  match /databases/{database}/documents {

    // ── Platform infrastructure (server-side only) ────────────────────────

    match /admin/{document} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /processedWebhookEvents/{eventId} {
      allow read, write: if false;
    }

    match /rateLimits/{docId} {
      allow read, write: if false;
    }

    match /plans/{planId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── Firebase Auth user profiles ───────────────────────────────────────

    match /users/{uid} {
      function isOwner() {
        return request.auth != null && request.auth.uid == uid;
      }

      allow read: if isOwner();

      allow update: if isOwner()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(["preferences", "displayName", "company", "updatedAt"])
        && (
          !("preferences" in request.resource.data.diff(resource.data).affectedKeys())
          || (
            request.resource.data.preferences.keys().hasOnly(["itemsPerPage"])
            && request.resource.data.preferences.itemsPerPage is number
          )
        );

      allow create: if false;

      match /preferences/{doc} {
        allow read, write: if isOwner();
      }

      match /notifications/{notificationId} {
        allow read: if isOwner();
        allow write: if false;
      }

      match /items/{itemId} {
        allow read: if isOwner();
        allow delete: if isOwner();
        allow create: if false;
        allow update: if false;
      }
    }

    // ── FieldStack Multi-tenant ───────────────────────────────────────────

    // Company membership lookup (flat collection for querying by uid)
    match /companyMembers/{memberDocId} {
      // Users can read their own memberships
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      // Server-side only writes
      allow write: if false;
    }

    // Company documents
    match /companies/{companyId} {
      function isMember() {
        return isAuthenticated() &&
          exists(/databases/$(database)/documents/companyMembers/$(companyId + "_" + request.auth.uid));
      }

      function isCompanyAdmin() {
        return isAuthenticated() &&
          get(/databases/$(database)/documents/companyMembers/$(companyId + "_" + request.auth.uid)).data.role == "ADMIN";
      }

      allow read: if isMember();
      // Company doc writes are server-side only (via Admin SDK)
      allow write: if false;

      // Projects
      match /projects/{projectId} {
        allow read: if isMember();
        allow write: if false; // server-side only

        // Project subcollections — readable by company members
        match /tasks/{taskId} {
          allow read: if isMember();
          allow write: if false;
        }

        match /orderItems/{itemId} {
          allow read: if isMember();
          allow write: if false;
        }

        match /scheduleChanges/{changeId} {
          allow read: if isMember();
          allow write: if false;
        }

        match /taskSteps/{stepId} {
          allow read: if isMember();
          allow write: if false;
        }

        match /feedEntries/{entryId} {
          allow read: if isMember();
          allow write: if false;
        }
      }

      // Team members
      match /teamMembers/{memberId} {
        allow read: if isMember();
        allow write: if false;
      }

      // Lead time settings
      match /leadTimeSettings/{settingId} {
        allow read: if isMember();
        allow write: if false;
      }

      // Chat messages — members can read their company's chat
      match /chatMessages/{messageId} {
        allow read: if isMember();
        allow write: if false;
      }

      // Gmail connection — admin only read (contains tokens)
      match /gmailConnection {
        allow read: if isCompanyAdmin();
        allow write: if false;
      }
    }
  }
}
