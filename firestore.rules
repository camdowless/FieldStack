rules_version = '2';
service cloud.firestore {
  function isAdmin() {
    return request.auth != null && request.auth.token.role == "admin";
  }

  function hasUserRole() {
    return request.auth != null && (request.auth.token.role == "user" || request.auth.token.role == "admin");
  }

  match /databases/{database}/documents {
    match /admin/{document} {
      allow read: if isAdmin();
      allow write: if false; // server-side only via Admin SDK
    }

    match /businesses/{cid} {
      allow read: if hasUserRole();
      allow write: if false; // server-side only via Admin SDK
    }

    match /jobs/{jobId} {
      allow read: if hasUserRole() && resource.data.uid == request.auth.uid;
      allow write: if false;

      match /results/{resultId} {
        allow read: if hasUserRole() && resource.data.uid == request.auth.uid;
        allow write: if false;
      }
    }

    match /reports/{reportId} {
      allow read: if false; // admin-only via Admin SDK
      allow write: if false; // server-side only via Admin SDK
    }

    match /users/{uid} {
      allow read: if hasUserRole() && request.auth.uid == uid;
      allow write: if false; // server-side only via Admin SDK

      // Allow users to update their own preferences
      match /preferences/{doc} {
        allow read, write: if hasUserRole() && request.auth.uid == uid;
      }

      match /searches/{searchId} {
        allow read: if hasUserRole() && request.auth.uid == uid;
        allow delete: if hasUserRole() && request.auth.uid == uid;
        allow create, update: if false; // server-side only via Admin SDK
      }

      match /savedLeads/{cid} {
        allow read, write: if hasUserRole() && request.auth.uid == uid;
      }
    }
  }
}
