{
  "name": "lead-finder-functions",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "test": "vitest run",
    "seed:plans": "node scripts/seedPlans.mjs",
    "seed:plans:emulator": "FIRESTORE_EMULATOR_HOST=127.0.0.1:8080 node scripts/seedPlans.mjs",
    "migrate:solopro": "node scripts/migrateUsersToSoloPro.mjs",
    "migrate:solopro:emulator": "FIRESTORE_EMULATOR_HOST=127.0.0.1:8080 node scripts/migrateUsersToSoloPro.mjs"
  },
  "engines": {
    "node": "22"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "cors": "^2.8.5",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0",
    "resend": "^6.12.2",
    "stripe": "^22.0.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "fast-check": "^3.23.2",
    "typescript": "^5.4.0",
    "vitest": "^4.1.4"
  }
}
