# ============================================
# Stripe
# ============================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs - create these in your Stripe dashboard
# then run: bun run seed:plans to write them to Firestore
STRIPE_PRICE_PRO=price_REPLACE_ME
STRIPE_PRICE_PRO_ANNUAL=price_REPLACE_ME
STRIPE_PRICE_AGENCY=price_REPLACE_ME
STRIPE_PRICE_AGENCY_ANNUAL=price_REPLACE_ME
STRIPE_PRICE_ENTERPRISE=price_REPLACE_ME
STRIPE_PRICE_ENTERPRISE_ANNUAL=price_REPLACE_ME

# ============================================
# App Branding (used in emails and API responses)
# ============================================
APP_NAME=FieldStack
APP_URL=https://your-app.web.app
SUPPORT_EMAIL=support@example.com
EMAIL_FROM=noreply@example.com

# ============================================
# CORS - comma-separated list of allowed origins
# ============================================
CORS_ORIGIN=https://your-app.web.app,https://your-app.firebaseapp.com

# ============================================
# Frontend URL (used for Stripe redirect URLs)
# ============================================
FRONTEND_URL=https://your-app.web.app

# ============================================
# Email (Resend)
# ============================================
RESEND_API_KEY=re_...

# ============================================
# Backups (optional)
# ============================================
BACKUP_BUCKET=gs://your-project-id-backups

# ============================================
# FieldStack — AI & Integrations
# ============================================

# Anthropic Claude API (required for schedule parsing and AI Foreman)
ANTHROPIC_API_KEY=sk-ant-...

# Gmail OAuth (required for Gmail integration)
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=...

# Procore OAuth (required for Procore integration)
PROCORE_CLIENT_ID=...
PROCORE_CLIENT_SECRET=...

# Twilio SMS (required for SMS briefing)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# Magic link JWT signing secret (for one-click task completion from emails)
MAGIC_LINK_SECRET=any-random-string-min-32-chars
