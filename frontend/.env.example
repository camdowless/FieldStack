# Copy this file to .env and fill in your values
# All VITE_ values come from Firebase Console → Project Settings → Your Apps → Web App

VITE_FIREBASE_API_KEY=AIzaSy...your-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abc123def456

# Local dev: emulator URL printed when you run firebase emulators:start
# Production: remove this line (firebase.json rewrite handles routing)
VITE_FUNCTIONS_URL=http://127.0.0.1:5001/your-project-id/us-central1
