rules_version = '2';
service cloud.firestore {
  function isAdmin() {
    return request.auth != null && request.auth.token.role == "admin";
  }

  function hasUserRole() {
    return request.auth != null && (request.auth.token.role == "user" || request.auth.token.role == "admin");
  }

  match /databases/{database}/documents {
    match /admin/{document} {
      allow read: if isAdmin();
      allow write: if false; // server-side only via Admin SDK
    }

    // Webhook deduplication — server-side only
    match /processedWebhookEvents/{eventId} {
      allow read, write: if false; // Admin SDK only
    }

    // Rate limit counters — server-side only
    match /rateLimits/{docId} {
      allow read, write: if false; // Admin SDK only
    }

    // Plan configuration — readable by all authenticated users, writable only via Admin SDK
    match /plans/{planId} {
      allow read: if request.auth != null;
      allow write: if false; // server-side only via Admin SDK (seedPlans function)
    }

    // User reports — server-side only
    match /reports/{reportId} {
      allow read: if false; // admin-only via Admin SDK
      allow write: if false; // server-side only via Admin SDK
    }

    // ── Company membership helper ─────────────────────────────────────────────
    // Reads users/{uid}.companyId and compares to the requested companyId.
    // NOTE: this incurs a Firestore read per rules evaluation. All heavy data
    // operations should go through Cloud Functions (Admin SDK) which bypass rules.
    function isMemberOfCompany(companyId) {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == companyId;
    }

    // ── Companies ────────────────────────────────────────────────────────────
    match /companies/{companyId} {
      allow read: if isMemberOfCompany(companyId);
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isMemberOfCompany(companyId);
      allow delete: if false; // server-side only
    }

    // ── Projects ─────────────────────────────────────────────────────────────
    match /projects/{projectId} {
      allow read: if request.auth != null
        && isMemberOfCompany(resource.data.companyId);
      allow create: if request.auth != null
        && isMemberOfCompany(request.resource.data.companyId);
      allow update: if request.auth != null
        && isMemberOfCompany(resource.data.companyId)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(["name", "address", "gcName", "gcContact", "gcEmail", "status", "updatedAt"]);
      allow delete: if false; // server-side only

      // Sub-collections: readable by company members; writes go through Cloud Functions
      match /scheduleUploads/{uploadId} {
        allow read: if request.auth != null
          && isMemberOfCompany(get(/databases/$(database)/documents/projects/$(projectId)).data.companyId);
        allow write: if false;
      }

      match /tasks/{taskId} {
        allow read: if request.auth != null
          && isMemberOfCompany(get(/databases/$(database)/documents/projects/$(projectId)).data.companyId);
        allow write: if false;
      }

      match /orderItems/{itemId} {
        allow read: if request.auth != null
          && isMemberOfCompany(get(/databases/$(database)/documents/projects/$(projectId)).data.companyId);
        // Allow client-side status/PO updates; all other fields are server-only
        allow update: if request.auth != null
          && isMemberOfCompany(get(/databases/$(database)/documents/projects/$(projectId)).data.companyId)
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(["status", "poNumber", "vendorName", "notes", "orderedAt", "updatedAt"]);
        allow create, delete: if false;
      }

      match /scheduleChanges/{changeId} {
        allow read: if request.auth != null
          && isMemberOfCompany(get(/databases/$(database)/documents/projects/$(projectId)).data.companyId);
        allow write: if false;
      }

      match /feedEntries/{entryId} {
        allow read: if request.auth != null
          && isMemberOfCompany(get(/databases/$(database)/documents/projects/$(projectId)).data.companyId);
        allow write: if false;
      }
    }

    match /users/{uid} {
      function isOwner() {
        return request.auth != null && request.auth.uid == uid;
      }

      allow read: if isOwner();

      // Allow users to update only the preferences field on their own profile
      allow update: if isOwner()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["preferences"]);

      allow create: if false; // server-side only via Admin SDK

      match /preferences/{doc} {
        allow read, write: if isOwner();
      }

      // Dunning / payment notifications written by server, read-only for the user
      match /notifications/{notificationId} {
        allow read: if isOwner();
        allow write: if false; // server-side only via Admin SDK
      }
    }
  }
}
